function oObject2_AnyClick(Object *theObject, CursorMode mode)
{
    if (!task_ob11_done)
    {
      open.Play();
      crawl.Play();
        theObject.SetView(24, 2, 1);
        theObject.Animate(0, 3, eOnce, eBlock);
        theObject.Clickable = true;
        task_ob11_done = true;
    }
    else
    {
        Display("nothing more！");
    }
}


function oObject0_AnyClick(Object *theObject, CursorMode mode)
{
  //theObject.SetView(22, 2, 1);
  //theObject.Animate(0, 3, eOnce, eBlock);
    if (!task_ob11_done)
    {
        Display("Look around!");
    }
    else if (!task_ob12_done)
    {
      flush.Play();
        theObject.SetView(22, 2, 1);
        theObject.Animate(0, 3, eOnce, eBlock);
        task_ob12_done = true;
    }
    else
    {
      cRoger.ChangeRoom(17, 158, 17);
    }
}


