// room script file

function room_FirstLoad()
{
  odoor.Visible=false;
  SetBackgroundFrame(1);
  scene.SetView(6, 1, 1);
  scene.Animate(0, 20, eOnce, eBlock);
  scene.Visible=false;
  odoor.Visible=true;  
  d7.Start();
}

function odoor_AnyClick(Object *theObject, CursorMode mode)
{
  cRoger.ChangeRoom(9, 43, 137);
}

