function oObject0_AnyClick(Object *theObject, CursorMode mode)
{
    if (!task_ot11_done)
    {
        theObject.X = 95; // X 坐标
        theObject.SetView(8, 2, 1);
        theObject.Animate(0, 3, eRepeat, eNoBlock);
        bubbles.Play();
        theObject.Clickable = true;
        task_ot11_done = true;

    }
    else
    {
        Display("nothing more！");
    }
}

function oObject1_AnyClick(Object *theObject, CursorMode mode)
{
    if (task_ot11_done && !task_ot12_done)
    {
        fidge.Play();
        theObject.X = 0;
        theObject.Y = 202;
        theObject.SetView(9, 2, 1);
        theObject.Animate(0, 3, eOnce, eBlock);
        task_ot12_done = true;
    }
    else if (!task_ot11_done)
    {
        Display("Look around!");
    }
    else
    {
        Display("Want some duck?");
    }
}

function oObject2_AnyClick(Object *theObject, CursorMode mode)
{
    if (!task_ot11_done)
    {
        Display("Don't bother me! Look around!");
    }
    else if (!task_ot12_done)
    {
        c8.Say("Give me some food from the fridge!");
    }
    else if (!task_ot13_done)
    {
        if (theObject.View == 7)
        {
            cRoger.ChangeRoom(15, 158, 17);
            task_ot13_done = true;
        }
        else
        {
              duck.Play();
              theObject.SetView(7, 2, 1);
              theObject.Animate(0, 3, eOnce, eBlock);
        }
    }
    else
    {
        Display("nothing more");
    }
}

function oObject3_AnyClick(Object *theObject, CursorMode mode)
{
  pop.Play();
  theObject.SetView(21, 2, 1);
  theObject.Animate(0, 3, eOnce, eBlock);

}

function room_AfterFadeIn()
{
  opendor.Play();
}
