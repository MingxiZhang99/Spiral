// room script file

function obp_AnyClick(Object *theObject, CursorMode mode)
{
    DisplayTopBar(10, 11, 17, "Stranger",  "remember me?");
  

}

function obp2_AnyClick(Object *theObject, CursorMode mode)
{
  theObject.SetView(5, 2, 1);
  theObject.Animate(0, 3, eOnce, eBlock);

}

function obs_AnyClick(Object *theObject, CursorMode mode)
{
  theObject.SetView(4, 2, 1);
  theObject.Animate(0, 3, eOnce, eBlock);
}
