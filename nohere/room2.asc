function ot11_AnyClick(Object *theObject, CursorMode mode)
{
    if (!task_ot11_done)
    {
        theObject.SetView(2, 2, 1);
        theObject.Animate(0, 3, eOnce, eBlock);
        task_ot11_done = true;

    }
    else
    {
        Display("nothing more！");
    }
}

function ot12_AnyClick(Object *theObject, CursorMode mode)
{
    if (task_ot11_done && !task_ot12_done)
    {
        theObject.SetView(2, 2, 1);
        theObject.Animate(0, 3, eOnce, eBlock);
        task_ot12_done = true;
    }
    else if (!task_ot11_done)
    {
        cRoger.Say("look task1");
    }
    else
    {
        Display("nothing more");
    }
}

function ot13_AnyClick(Object *theObject, CursorMode mode)
{
    if (!task_ot11_done)
    {
        cRoger.Say("look task1");
    }
    else if (!task_ot12_done)
    {
        cRoger.Say("look task2");
    }
    else if (!task_ot13_done)
    {
        if (theObject.View == 2)
        {
            cRoger.ChangeRoom(3, 43, 137);
            task_ot13_done = true;
        }
        else
        {
            theObject.SetView(2, 2, 1);
            theObject.Animate(0, 3, eOnce, eBlock);
        }
    }
    else
    {
        Display("nothing more");
    }
}

