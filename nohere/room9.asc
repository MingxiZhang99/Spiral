

function oObject0_AnyClick(Object *theObject, CursorMode mode)
{
  theObject.SetView(10, 2, 1);
  theObject.Animate(0, 3, eRepeat, eNoBlock);
  theObject.Clickable = true;
  
  task_ot11_done = true;
  fox.Play();

  bedroom.Start();
  oObject1.Clickable=true;
}

function oObject1_AnyClick(Object *theObject, CursorMode mode)
{
  player.ChangeRoom(14);
}
  


function room_AfterFadeIn()
{
  opendor.Play();
  oObject1.Clickable=false;

}

function oObject2_AnyClick(Object *theObject, CursorMode mode)
{
  duckw.Play();
  theObject.SetView(26, 2, 1);
  theObject.Animate(0, 3, eOnce, eBlock);
}
