// room script file


function room_FirstLoad()
{
  smail.Visible=false;
  //SetBackgroundFrame(1);
  laugh.Play();
  owall.SetView(18, 1, 1);
  owall.Animate(0, 10, eOnce, eBlock);
  owall.Visible=false;
  smail.Visible=true;  
}


function smail_AnyClick(Object *theObject, CursorMode mode)
{
  cRoger.ChangeRoom(8, 43, 137);
}